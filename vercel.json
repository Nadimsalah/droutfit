{
    "headers": [
        {
            "source": "/widget/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "frame-ancestors *"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "ALLOWALL"
                }
            ]
        },
        {
            "source": "/app/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "frame-ancestors 'self' https://admin.shopify.com https://*.myshopify.com https://*.shopify.com"
                }
            ]
        },
        {
            "source": "/dashboard/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "frame-ancestors 'self' https://admin.shopify.com https://*.myshopify.com https://*.shopify.com"
                }
            ]
        },
        {
            "source": "/(en|fr|ar)/dashboard",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "frame-ancestors 'self' https://admin.shopify.com https://*.myshopify.com https://*.shopify.com"
                }
            ]
        },
        {
            "source": "/(en|fr|ar)/dashboard/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "frame-ancestors 'self' https://admin.shopify.com https://*.myshopify.com https://*.shopify.com"
                }
            ]
        }
    ]
}